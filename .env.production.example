# ==================================================
# EUP Project Information System — PRODUCTION ENV
# Salin ke .env dan isi semua nilai sebelum deploy
# ==================================================

# Database (ganti USER, PASSWORD, HOST sesuai server)
DATABASE_URL="postgresql://eupadmin:GANTI_PASSWORD_KUAT@db:5432/eup_pis"

# NextAuth (ganti URL dan generate secret baru)
NEXTAUTH_URL="http://SERVER_IP:8020"
NEXTAUTH_SECRET="GANTI_DENGAN_RANDOM_STRING_64_KARAKTER_openssl_rand_-base64_64"

# PostgreSQL container
POSTGRES_DB="eup_pis"
POSTGRES_USER="eupadmin"
POSTGRES_PASSWORD="GANTI_PASSWORD_KUAT"

# Admin seed password
SEED_ADMIN_PASSWORD="GANTI_SEBELUM_PRODUCTION"
